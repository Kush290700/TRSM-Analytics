ENV=production
FORCE_HTTPS=true
DEV_INSECURE_COOKIES=false
FLASK_ENV=production
SECRET_KEY=change_me

# Data loader / refresh behaviour
PARQUET_PATH=cache/fact_dataset
FACT_DATASET_PATH=cache/fact_dataset
DIRECT_SQL_ONLY=true
AUTO_REFRESH_ENABLED=false
REFRESH_EVERY_MIN=60
ENABLE_INPROCESS_REFRESH=0
ALLOW_GUNICORN_INPROCESS_REFRESH=0
FACT_REFRESH_INTERVAL_SECONDS=300
FACT_REFRESH_LOOKBACK_DAYS=14
FACT_REFRESH_JITTER_SECONDS=15
ORDER_STATUSES=packed,invoiced,shipped,delivered
DB_READ_UNCOMMITTED=true
CACHE_DIR=cache
CACHE_TTL_MINUTES=15
INITIAL_START_DATE=2017-01-01
INITIAL_END_DATE=
INCREMENTAL_LOOKBACK_DAYS=7
INCREMENTAL_COLUMN=UpdatedAt
LABOR_ANALYTICS_ENABLED=1
LABOR_PAGE_DEFAULT_DAYS=90
LABOR_START_DATE=2022-01-01
LABOR_PARQUET_PATH=cache/labor/fact_dataset
LABOR_RAW_PATH=cache/labor/raw
LABOR_INCREMENTAL_DAYS=7
LABOR_RECENT_RELOAD_DAYS=45
LABOR_REFRESH_INTERVAL_SECONDS=3600

# Synerion labor source
SYNERION_BASE_URL=https://api.synerionagile.com
SYNERION_USERNAME=
SYNERION_PASSWORD=
SYNERION_API_KEY=
SYNERION_SUBDOMAIN=
SYNERION_APP_REGION=CAE
SYNERION_PER_PAGE=100
SYNERION_CONNECT_TIMEOUT_SECONDS=10
SYNERION_READ_TIMEOUT_SECONDS=60
SYNERION_MAX_RETRIES=4
SYNERION_BACKOFF_FACTOR=1.0

# Visibility + user management
USERS_CSV_PATH=/var/opt/trsm/users/userid.csv
VISIBILITY_GRANTS_JSON=/var/opt/trsm/visibility_grants.json
ADMIN_PORTAL_ENABLED=1
AUTHZ_DB_PERMISSIONS=1
AUTHZ_ENFORCEMENT=0
AUTHZ_ENFORCEMENT_MODE=warn
ADMIN_USER_SELECT=1
INVITES_ENABLED=1
RESET_TOKEN_TTL_SECONDS=86400
APP_PUBLIC_BASE_URL=https://analytics.example.com
SALESREPS_V2=0
SALESREP_DRILLDOWN_V2=0
PRODUCT_INTELLIGENCE_V2=0
PRODUCTS_V3=0
PRODUCTS_V4=0
PRODUCT_DRILLDOWN_V2=0
PRODUCT_FORECAST_V1=0
SUPPLIER_DRILLDOWN_V2=0
CUSTOMERS_KPIS_V2=0
CUSTOMERS_KPIS_V3=0
CUSTOMERS_RFM_V2=0
CUSTOMERS_CLV_V2=0
OVERVIEW_V2=0
OVERVIEW_V3=0
OVERVIEW_FORECAST_V2=0
OVERVIEW_MOVERS_FAST=0
AI_ENABLED=0
AI_PROVIDER=ollama
AI_MODEL=llama3.1:8b-instruct-q4_K_M
AI_BASE_URL=http://127.0.0.1:11434
AI_MODEL_PATH=
AI_TIMEOUT_SECONDS=25
AI_CONTEXT_WINDOW=4096
AI_MAX_TOKENS=384
AI_THREADS=2
AI_BATCH_SIZE=256
AI_GPU_LAYERS=0
AI_MAX_TOOL_CALLS=6
AI_ENABLE_RAG=1
AI_ENABLE_AUDIT=1
AI_ENABLE_PAGE_CONTEXT=1
AI_ENABLE_SUGGESTED_PROMPTS=1
AI_ENABLE_GLOSSARY=1
AI_ENABLE_PROACTIVE_INSIGHTS=1
AI_ENABLE_WORKFLOW_ASSIST=1
AI_ENABLE_VOICE_READY=1
AI_MAX_PROACTIVE_ITEMS=6
AI_REQUIRE_TOOL_BACKING_FOR_METRICS=1

# SMTP relay (Outlook EOP, no SMTP AUTH)
SMTP_SERVER=tworiversmeats-com.mail.protection.outlook.com
SMTP_PORT=25
SMTP_USE_TLS=0
MAIL_FROM=TRSM Analytics <no-reply@tworiversmeats.com>
# SMTP_USER and SMTP_PASS are intentionally unused for relay mode.

# MSSQL connection vars
MSSQL_SERVER=YOUR_SQL_HOST
MSSQL_DB=TRSM
MSSQL_USER=YOUR_USER
MSSQL_PASSWORD=YOUR_PASS
MSSQL_TRUSTED=true
MSSQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_CONN_STR=
